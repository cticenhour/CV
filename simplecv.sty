\ProvidesPackage{simplecv}[2026/03/02 v1.2 Simple cv style]

% Required sub-packages
\RequirePackage[margin=0.5in, footskip=0.1in]{geometry}
\RequirePackage{tabularx}
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,        % false: boxed links; true: colored links
    urlcolor=black          % color of external links
}
\RequirePackage[
	style=numeric,			% Bibliography entry style
	sorting=none,				% No special sorting - order of items are identical to order in bib file
	maxnames=99,				% Max number of names displayed
	giveninits=true			% Show only first letter of given name
]{biblatex}

% Remove page numbers
%\pagenumbering{gobble}

% Indent padding
\newcommand{\coli}{\hspace{3em}}  % left column indent
\newcommand{\colii}{\hspace{2em}} % right column indent
\newcommand{\coliii}{\hspace{1.5em}} % second line indent
\newcommand{\coliv}{\hspace{1em}} % second line indent - alt

% Vertical space consistency
\newcommand{\cvsep}{& & \\}  % for three-col sections

% Bullet points
\newcommand{\tabitem}{~~\textbullet~~}
\newcommand{\tabitemii}{~~$\circ$~~}

% Command to generate CV sections, given a heading, tabularx column specifier options, and content
\newcommand{\cvsection}[3]{
	\subsection*{#1}
	\begin{tabularx}{\textwidth}{#2}
		#3
	\end{tabularx}
}

% Shorthands of cvsection for different distinct sections
\newcommand{\cvtwocol}[2]{\cvsection{#1}{l X}{#2}}
\newcommand{\cvthreecol}[2]{\cvsection{#1}{l X r}{#2}}
\newcommand{\cvcontact}[2]{\cvsection{#1}{r l}{#2}}

% Structured entry header for a position or institution.
% Args: #1 = institution/employer, #2 = role/degree, #3 = date range
\newcommand{\cventry}[3]{%
	& \textbf{#1} & \\
	& \textit{#2} & \textbf{#3} \\
}

% Entry header for a subsequent role at the same institution (omits institution name).
% Args: #1 = role/degree, #2 = date range
\newcommand{\cventrysub}[2]{%
	& \textit{#1} & \textbf{#2} \\
}

% Bullet point row, hiding raw table column syntax from content.
% Use \cvbullet for a standard bullet and \cvbulletcont for a
% continuation line when a bullet wraps to a second line.
\newcommand{\cvbullet}[1]{& \tabitem #1 & \\}
\newcommand{\cvbulletcont}[1]{& \colii #1 & \\}

% Shorthands for communication
% Args: #1 = entry label, #2 = entry definition
\newcommand{\cvcontactentry}[2]{\coli #1: & \colii #2 \\}

% Command to display reference list, given a section heading and a bib file.
\newcommand{\reflist}[2]{
	\subsection*{#1}
	\begin{refsection}[#2]
		\nocite{*}
		\printbibliography[heading=none]
	\end{refsection}
}

% Use Biblatex data annotation feature to bold name in each reference list entry
% See https://tex.stackexchange.com/a/304968
% KEY:
%	- highlight = make name bold
%	- pi = signify PI on grant by adding a double-asterisk (**) after the last name
%	- highlightpi = performs the actions of "highlight" and "pi" at the same time
%
% Modify given name command
\renewcommand*{\mkbibnamegiven}[1]{%
  \ifitemannotation{highlight}{\textbf{#1}}
  	{\ifitemannotation{pi}{#1}
	  {\ifitemannotation{highlightpi}{\textbf{#1}}{#1}}}}
% Modify family name/surname command
\renewcommand*{\mkbibnamefamily}[1]{%
  \ifitemannotation{highlight}{\textbf{#1}}
    {\ifitemannotation{pi}{#1**}
	  {\ifitemannotation{highlightpi}{\textbf{#1}**}{#1}}}}
