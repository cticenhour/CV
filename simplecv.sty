% Created by Casey Icenhour (GitHub: @cticenhour)
\ProvidesPackage{simplecv}[2026/03/02 v2.0 Simple cv style]

% Required sub-packages
\RequirePackage[margin=0.5in, footskip=0.1in]{geometry}
\RequirePackage{tabularx}
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,        % false: boxed links; true: colored links
    urlcolor=black          % color of external links
}
\RequirePackage[
	style=numeric,			% Bibliography entry style
	sorting=none,				% No special sorting - order of items are identical to order in bib file
	maxnames=99,				% Max number of names displayed
	giveninits=true			% Show only first letter of given name
]{biblatex}

% Remove page numbers
%\pagenumbering{gobble}

% Name heading
\newcommand{\cvname}[1]{%
	\begin{center}
		{\huge \textbf{#1}}
	\end{center}
}

% Indent padding
\newcommand{\coli}{\hspace{1em}}
\newcommand{\colii}{\hspace{2em}}
\newcommand{\coliii}{\hspace{3em}}

% Section command for a single paragraph of text, e.g. Research Interests.
% Args: #1 = section heading, #2 = paragraph text
\newcommand{\cvparagraph}[2]{%
	\subsection*{#1}
	\begingroup
		\leftskip=2.5em
		#2\par
	\endgroup
}

% Command to generate CV sections, given a heading, tabularx column specifier options, and content
\newcommand{\cvsection}[3]{
	\subsection*{#1}
	\begin{tabularx}{\textwidth}{#2}
		#3
	\end{tabularx}
}

% Shorthands of cvsection for different distinct sections
\newcommand{\cvtwocol}[2]{\cvsection{#1}{l X}{#2}}
\newcommand{\cvskills}[2]{\cvsection{#1}{@{\coliii} l >{\raggedleft\arraybackslash}X}{#2}}
\newcommand{\cvcontact}[2]{\cvsection{#1}{r X}{#2}}

% Section command for experience-style entries, where bullets follow each
% entry header as a proper list rather than table rows.
% Args: #1 = section heading
\newcommand{\cventries}[2]{
	\subsection*{#1}
	\begin{list}{}{%
		\setlength{\leftmargin}{2em}
		\setlength{\itemsep}{0pt}
		\setlength{\parsep}{0pt}
	}
	#2
	\end{list}
}

% Structured entry header for a position or institution, for use inside \cventries.
% Emits a self-contained tabularx for the institution/role/date header rows.
% Args: #1 = institution/employer, #2 = role/degree, #3 = date range
\newcommand{\cventry}[3]{%
	\item[]
	\begin{tabularx}{\linewidth}{X r}
		\textbf{#1} & \\
		\textit{#2} & \textbf{#3} \\
	\end{tabularx}
}

% Entry header for an educational institution, for use inside \cventries.
% Writes out the full degree name in italics rather than an abbreviation column.
% Args: #1 = institution and field, #2 = full degree name, #3 = year
\newcommand{\cveduentry}[3]{%
	\item[]
	\begin{tabularx}{\linewidth}{X r}
		\textbf{#1} & \\
		\textit{#2} & \textbf{#3} \\
	\end{tabularx}
}

% Structured entry header for an award, for use inside \cventries.
% Emits a self-contained tabularx for the award/date header rows.
% Args: #1 = award name, #2 = date range
\newcommand{\cvawardentry}[2]{%
	\item[]
	\begin{tabularx}{\linewidth}{X r}
		#1 & \textbf{#2} \\
	\end{tabularx}
}

% Special case of \cvawardentry, used for memberships.
% Emits a self-contained tabularx for the membership rows.
% Args: #1 = membership name
\newcommand{\cvmemberentry}[1]{\cvawardentry{#1}{}}

% Skills entries
\newcommand{\cvskillsentry}[2]{\textbf{#1} & #2 \\}

% Contacts entries
\newcommand{\cvcontactentry}[2]{\coliii #1: & \colii #2 \\}

% Entry header for a subsequent role at the same institution (omits institution name).
% Args: #1 = role/degree, #2 = date range
\newcommand{\cventrysub}[2]{%
	\item[]
	\begin{tabularx}{\linewidth}{X r}
		\textit{#1} & \textbf{#2} \\
	\end{tabularx}
}

% Bullet list for use inside \cventries. Wrapping and indentation are handled
% automatically by the list environment; \cvbulletcont is no longer needed.
% Args: #1 = one or more \item lines
\newcommand{\cvbullets}[1]{%
	\begin{itemize}
		\setlength{\itemsep}{0pt}
		\setlength{\parsep}{0pt}
		#1
	\end{itemize}
}

% Command to display reference list, given a section heading and a bib file.
\newcommand{\reflist}[2]{
	\subsection*{#1}
	\begin{refsection}[#2]
		\nocite{*}
		\printbibliography[heading=none]
	\end{refsection}
}

% Use Biblatex data annotation feature to bold name in each reference list entry
% See https://tex.stackexchange.com/a/304968
% KEY:
%	- highlight    = make name bold
%	- pi           = signify PI on grant by adding a double-asterisk (**) after the last name
%	- highlightpi  = performs the actions of "highlight" and "pi" at the same time
%
% Modify given name command
\renewcommand*{\mkbibnamegiven}[1]{%
  \ifitemannotation{highlight}{\textbf{#1}}
  	{\ifitemannotation{pi}{#1}
	  {\ifitemannotation{highlightpi}{\textbf{#1}}{#1}}}}
% Modify family name/surname command
\renewcommand*{\mkbibnamefamily}[1]{%
  \ifitemannotation{highlight}{\textbf{#1}}
    {\ifitemannotation{pi}{#1**}
	  {\ifitemannotation{highlightpi}{\textbf{#1}**}{#1}}}}
